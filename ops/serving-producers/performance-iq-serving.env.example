# Performance IQ target.
PIQ_BASE_URL=http://127.0.0.1:3002
PIQ_TOKEN=

# Use the same model across every serving engine so dashboard rows are comparable.
PIQ_SERVING_MODEL=Qwen/Qwen2.5-0.5B-Instruct
PIQ_SERVING_REPETITIONS=3
PIQ_SERVING_MAX_TOKENS=64
PIQ_SERVING_HARDWARE=three-engine-serving-smoke
PIQ_SERVING_OPERATING_POINT=serving-smoke
PIQ_ARTIFACT_DIR=./performance-iq-output/serving-producers
# Required for strict proof cost completeness. Set to your actual blended
# per-GPU hourly cost for the tested hardware.
PIQ_SERVING_USD_PER_GPU_HOUR=
PIQ_SERVING_GPU_COUNT=1
# Optional override; DCGM observed power is used when this is unset.
PIQ_SERVING_POWER_WATTS_PER_GPU=
# Full proof defaults are strict. Engines must support OpenAI-compatible
# logprobs/top_logprobs for token IDs/logprobs to be populated.
PIQ_SERVING_CAPTURE_TOKEN_DETAILS=true
PIQ_SERVING_TOP_LOGPROBS=5
# Full proof requires native serving metrics and DCGM hardware counters. Turn
# these off only for local setup debugging or partial proofs.
PIQ_SERVING_COLLECT_HARDWARE_METRICS=true
PIQ_SERVING_REQUIRE_NATIVE_TELEMETRY=true
PIQ_SERVING_REQUIRE_HARDWARE_TELEMETRY=true
# Optional explicit path for the overall smoke proof summary JSON.
# PIQ_SERVING_SUMMARY_OUT=./performance-iq-output/serving-producers/latest-serving-smoke-proof.json
# Optional request receipt log. Set this when routing through receipt-proxy.
# PIQ_SERVING_RECEIPT_LOG=./performance-iq-output/serving-producers/request-receipts.jsonl

# Optional local operator environment. Use these when the smoke runner and
# serving framework packages live outside the default PATH/PYTHONPATH.
# PIQ_PYTHON_BIN=/opt/miniconda3/bin/python
# Colon-separated PATH entries are allowed here for multiple framework venvs.
# PIQ_SERVING_BIN_DIR=/opt/miniconda3/bin
# PIQ_VLLM_SOURCE_PATH=/Users/admin/vllm
# PIQ_SGLANG_SOURCE_PATH=/Users/admin/sglang
# PIQ_COMMAND_PROBE_TIMEOUT_SECONDS=35
# Set true only for local one-engine debugging. Full proof runs leave this off.
# PIQ_SERVING_ALLOW_PARTIAL=false

# Engine endpoints. Keep these aligned with docker-compose.nvidia.yaml or your
# remote engine URLs.
PIQ_VLLM_URL=http://127.0.0.1:8000
PIQ_SGLANG_URL=http://127.0.0.1:30000
PIQ_TENSORRT_LLM_URL=http://127.0.0.1:8001

# Optional native engine Prometheus endpoints.
PIQ_VLLM_METRICS_URL=http://127.0.0.1:8000/metrics
PIQ_SGLANG_METRICS_URL=http://127.0.0.1:30000/metrics
PIQ_TENSORRT_LLM_METRICS_URL=http://127.0.0.1:8001/metrics

# DCGM exporter endpoint for hardware sensor counters. The docker-compose
# template exposes this on localhost:9400 for host-run smoke commands.
PIQ_VLLM_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics
PIQ_SGLANG_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics
PIQ_TENSORRT_LLM_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics

# Optional engine API keys when the OpenAI-compatible endpoints require auth.
PIQ_VLLM_API_KEY=
PIQ_SGLANG_API_KEY=
PIQ_TENSORRT_LLM_API_KEY=

# Optional image pins for docker-compose.nvidia.yaml.
PIQ_DCGM_EXPORTER_IMAGE=nvcr.io/nvidia/k8s/dcgm-exporter:latest
PIQ_VLLM_IMAGE=vllm/vllm-openai:latest
PIQ_SGLANG_IMAGE=lmsysorg/sglang:latest
PIQ_TENSORRT_LLM_IMAGE=

# Optional runtime provenance. These values are redacted into dashboard-safe
# hashes/IDs and preserved in operator artifacts. Set per-engine values when
# engines run in different containers, pods, or hosts.
# PIQ_VLLM_FRAMEWORK_VERSION=
# PIQ_VLLM_MODEL_REVISION=
# PIQ_VLLM_IMAGE_TAG=
# PIQ_VLLM_IMAGE_DIGEST=
# PIQ_VLLM_SERVER_ARGS='["vllm","serve","Qwen/Qwen2.5-0.5B-Instruct"]'
# PIQ_VLLM_PROCESS_ID=
# PIQ_VLLM_CONTAINER_ID=
# PIQ_VLLM_POD_NAME=
# PIQ_VLLM_NODE_NAME=
# PIQ_VLLM_HOST_NAME=
# PIQ_SGLANG_FRAMEWORK_VERSION=
# PIQ_SGLANG_MODEL_REVISION=
# PIQ_SGLANG_IMAGE_TAG=
# PIQ_SGLANG_IMAGE_DIGEST=
# PIQ_SGLANG_SERVER_ARGS='["python","-m","sglang.launch_server"]'
# PIQ_SGLANG_PROCESS_ID=
# PIQ_SGLANG_CONTAINER_ID=
# PIQ_SGLANG_POD_NAME=
# PIQ_SGLANG_NODE_NAME=
# PIQ_SGLANG_HOST_NAME=
# PIQ_TENSORRT_LLM_FRAMEWORK_VERSION=
# PIQ_TENSORRT_LLM_MODEL_REVISION=
# PIQ_TENSORRT_LLM_IMAGE_TAG=
# PIQ_TENSORRT_LLM_IMAGE_DIGEST=
# PIQ_TENSORRT_LLM_SERVER_ARGS='["trtllm-serve","Qwen/Qwen2.5-0.5B-Instruct"]'
# PIQ_TENSORRT_LLM_PROCESS_ID=
# PIQ_TENSORRT_LLM_CONTAINER_ID=
# PIQ_TENSORRT_LLM_POD_NAME=
# PIQ_TENSORRT_LLM_NODE_NAME=
# PIQ_TENSORRT_LLM_HOST_NAME=

# Hugging Face cache/auth used by engine containers.
# Set HF_HOME to an absolute path if the default ~/.cache/huggingface is not
# where your model cache lives.
# HF_HOME=/home/ubuntu/.cache/huggingface
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
