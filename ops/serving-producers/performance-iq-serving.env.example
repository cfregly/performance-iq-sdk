# Performance IQ target.
PIQ_BASE_URL=http://127.0.0.1:3002
PIQ_TOKEN=

# Use the same model across every serving engine so dashboard rows are comparable.
PIQ_SERVING_MODEL=Qwen/Qwen2.5-0.5B-Instruct
PIQ_SERVING_MODEL_REVISION=7ae557604adf67be50417f59c2c2f167def9a775
PIQ_SERVING_MAX_MODEL_LEN=1024
PIQ_SERVING_MAX_CONCURRENCY=8
PIQ_SERVING_REPETITIONS=3
PIQ_SERVING_MAX_TOKENS=64
# The NVIDIA runner replaces hardware with the GPU name observed by nvidia-smi.
PIQ_SERVING_HARDWARE=unresolved-nvidia-gpu
PIQ_SERVING_OPERATING_POINT=single-gpu-co-resident-three-engine
PIQ_ARTIFACT_DIR=./performance-iq-output/serving-producers
# Required for strict proof cost completeness. Set to your actual blended
# per-GPU hourly cost for the tested hardware.
PIQ_SERVING_USD_PER_GPU_HOUR=
PIQ_SERVING_GPU_COUNT=1
# Optional override; DCGM observed power is used when this is unset.
PIQ_SERVING_POWER_WATTS_PER_GPU=
# Full proof defaults are strict. Engines must support OpenAI-compatible
# logprobs/top_logprobs for output token logprobs to be populated.
PIQ_SERVING_CAPTURE_TOKEN_DETAILS=true
PIQ_SERVING_TOP_LOGPROBS=5
# Strict smoke uses the Hugging Face tokenizer to resolve token IDs when an
# engine returns token text/logprobs but omits token_id fields, or when a local
# runtime can stream text safely but cannot return decode logprobs. Leave
# PIQ_SERVING_TOKENIZER_MODEL blank to use PIQ_SERVING_MODEL.
PIQ_SERVING_RESOLVE_TOKEN_IDS_WITH_TOKENIZER=true
PIQ_SERVING_TOKENIZER_MODEL=
# Full proof requires native serving metrics and DCGM hardware counters. Turn
# these off only for local setup debugging or partial proofs.
PIQ_SERVING_COLLECT_HARDWARE_METRICS=true
PIQ_SERVING_REQUIRE_NATIVE_TELEMETRY=true
PIQ_SERVING_REQUIRE_HARDWARE_TELEMETRY=true
# Strict product proof runs should verify the saved proof bundle immediately and
# fail unless every product telemetry category is proven. Leave these true for
# strict-smoke and strict-recorded-smoke; turn them off only for setup debugging.
PIQ_SERVING_VERIFY_AFTER_CAPTURE=true
PIQ_SERVING_REQUIRE_TELEMETRY_COVERAGE=true
# Optional explicit path for the overall smoke proof summary JSON.
# PIQ_SERVING_SUMMARY_OUT=./performance-iq-output/serving-producers/latest-serving-smoke-proof.json
# Optional request receipt log. Set this when routing through receipt-proxy.
# PIQ_SERVING_RECEIPT_LOG=./performance-iq-output/serving-producers/request-receipts.jsonl
# Optional post-capture JSONL event log. This is written after
# request timing is captured, so it is not on the TTFT/TPOT measurement path.
# PIQ_SERVING_EVENT_LOG=./performance-iq-output/serving-producers/serving-events.jsonl
PIQ_SERVING_EVENT_TOPIC=performance-iq.serving.telemetry.v1
# Kafka export is experimental and is configured only under experimental/kafka.

# Optional local operator environment. Use these when the smoke runner and
# serving framework packages live outside the default PATH/PYTHONPATH.
# PIQ_PYTHON_BIN=/opt/miniconda3/bin/python
# Colon-separated PATH entries are allowed here for multiple framework venvs.
# PIQ_SERVING_BIN_DIR=/opt/miniconda3/bin
# PIQ_VLLM_SOURCE_PATH=/Users/admin/vllm
# PIQ_SGLANG_SOURCE_PATH=/Users/admin/sglang
# PIQ_COMMAND_PROBE_TIMEOUT_SECONDS=35
# Set true only for local one-engine debugging. Full proof runs leave this off.
# PIQ_SERVING_ALLOW_PARTIAL=false

# Engine endpoints. Keep these aligned with docker-compose.nvidia.yaml or your
# remote engine URLs.
PIQ_VLLM_URL=http://127.0.0.1:8000
PIQ_SGLANG_URL=http://127.0.0.1:30000
PIQ_TENSORRT_LLM_URL=http://127.0.0.1:8001

# Optional native engine Prometheus endpoints. TensorRT-LLM also exposes
# iteration-stat JSON at /metrics; keep both URLs when available.
PIQ_VLLM_METRICS_URL=http://127.0.0.1:8000/metrics
PIQ_SGLANG_METRICS_URL=http://127.0.0.1:30000/metrics
PIQ_TENSORRT_LLM_METRICS_URL=http://127.0.0.1:8001/prometheus/metrics
PIQ_TENSORRT_LLM_JSON_METRICS_URL=http://127.0.0.1:8001/metrics
PIQ_TENSORRT_LLM_PERF_METRICS_URL=http://127.0.0.1:8001/perf_metrics

# DCGM exporter endpoint for hardware sensor counters. The docker-compose
# template exposes this on localhost:9400 for host-run smoke commands.
PIQ_VLLM_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics
PIQ_SGLANG_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics
PIQ_TENSORRT_LLM_HARDWARE_METRICS_URL=http://127.0.0.1:9400/metrics

# Optional engine API keys when the OpenAI-compatible endpoints require auth.
PIQ_VLLM_API_KEY=
PIQ_SGLANG_API_KEY=
PIQ_TENSORRT_LLM_API_KEY=

# Reproducible NVIDIA compose defaults. Update these deliberately and validate
# their registry manifests before changing the proof baseline.
PIQ_DCGM_EXPORTER_IMAGE=nvcr.io/nvidia/k8s/dcgm-exporter:4.5.3-4.8.2-distroless@sha256:60d3b00ac80b4ae77f94dae2f943685605585ad9e92fdccda3154d009ae317cc
PIQ_VLLM_IMAGE=vllm/vllm-openai:v0.23.0@sha256:6d8429e38e3747723ca07ee1b17972e09bb9c51c4032b266f24fb1cc3b22ed8f
PIQ_SGLANG_IMAGE=lmsysorg/sglang:v0.5.12@sha256:42194170546745092e74cd5f81ad32a7c6e944c7111fe7bf13588152277ff356
PIQ_TENSORRT_LLM_IMAGE=nvcr.io/nvidia/tensorrt-llm/release:1.2.1@sha256:33cd085b772947bd22b7273886539331420404e5d2a4a039945241945ff927b9
PIQ_DCGM_EXPORTER_INTERVAL_MS=33

# Allow all three 0.5B engines to share one GPU for a comparable smoke run.
# Increase these only when the GPU has enough free memory for all three
# frameworks plus their CUDA contexts and activation buffers.
PIQ_SERVING_CUDA_VISIBLE_DEVICES=0
PIQ_VLLM_GPU_MEMORY_UTILIZATION=0.20
PIQ_SGLANG_MEM_FRACTION_STATIC=0.20
PIQ_TENSORRT_LLM_KV_CACHE_FRACTION=0.20
PIQ_TENSORRT_LLM_MAX_NUM_TOKENS=1024
PIQ_TENSORRT_LLM_BACKEND=tensorrt

# Runtime-provenance defaults. The NVIDIA E2E runner replaces framework
# version, image identity, effective entrypoint/command, process/container,
# model revision, and host/node values with observations from live containers.
# Other launch paths should set these per engine. Dashboard rows retain safe
# hashes/IDs; operator artifacts preserve the full values.
PIQ_VLLM_FRAMEWORK_VERSION=0.23.0
PIQ_VLLM_RUNTIME_BACKEND=cuda
PIQ_VLLM_MODEL_REVISION=7ae557604adf67be50417f59c2c2f167def9a775
PIQ_VLLM_IMAGE_TAG=vllm/vllm-openai:v0.23.0@sha256:6d8429e38e3747723ca07ee1b17972e09bb9c51c4032b266f24fb1cc3b22ed8f
# PIQ_VLLM_IMAGE_DIGEST=
PIQ_VLLM_SERVER_ARGS='["vllm","serve","Qwen/Qwen2.5-0.5B-Instruct","--revision","7ae557604adf67be50417f59c2c2f167def9a775","--gpu-memory-utilization","0.20"]'
PIQ_VLLM_TOKENIZER_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# PIQ_VLLM_PROCESS_ID=
# PIQ_VLLM_CONTAINER_ID=
# PIQ_VLLM_POD_NAME=
# PIQ_VLLM_NODE_NAME=
# PIQ_VLLM_HOST_NAME=
PIQ_SGLANG_FRAMEWORK_VERSION=0.5.12
PIQ_SGLANG_RUNTIME_BACKEND=cuda
PIQ_SGLANG_MODEL_REVISION=7ae557604adf67be50417f59c2c2f167def9a775
PIQ_SGLANG_IMAGE_TAG=lmsysorg/sglang:v0.5.12@sha256:42194170546745092e74cd5f81ad32a7c6e944c7111fe7bf13588152277ff356
# PIQ_SGLANG_IMAGE_DIGEST=
PIQ_SGLANG_SERVER_ARGS='["python","-m","sglang.launch_server","--model-path","Qwen/Qwen2.5-0.5B-Instruct","--revision","7ae557604adf67be50417f59c2c2f167def9a775","--mem-fraction-static","0.20"]'
PIQ_SGLANG_TOKENIZER_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# PIQ_SGLANG_PROCESS_ID=
# PIQ_SGLANG_CONTAINER_ID=
# PIQ_SGLANG_POD_NAME=
# PIQ_SGLANG_NODE_NAME=
# PIQ_SGLANG_HOST_NAME=
PIQ_TENSORRT_LLM_FRAMEWORK_VERSION=1.2.1
PIQ_TENSORRT_LLM_RUNTIME_BACKEND=tensorrt
PIQ_TENSORRT_LLM_MODEL_REVISION=7ae557604adf67be50417f59c2c2f167def9a775
PIQ_TENSORRT_LLM_IMAGE_TAG=nvcr.io/nvidia/tensorrt-llm/release:1.2.1@sha256:33cd085b772947bd22b7273886539331420404e5d2a4a039945241945ff927b9
# PIQ_TENSORRT_LLM_IMAGE_DIGEST=
PIQ_TENSORRT_LLM_SERVER_ARGS='["trtllm-serve","Qwen/Qwen2.5-0.5B-Instruct","--backend","tensorrt","--revision","7ae557604adf67be50417f59c2c2f167def9a775","--kv_cache_free_gpu_memory_fraction","0.20","--config","/etc/performance-iq/tensorrt-llm-config.yaml"]'
PIQ_TENSORRT_LLM_TOKENIZER_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# PIQ_TENSORRT_LLM_PROCESS_ID=
# PIQ_TENSORRT_LLM_CONTAINER_ID=
# PIQ_TENSORRT_LLM_POD_NAME=
# PIQ_TENSORRT_LLM_NODE_NAME=
# PIQ_TENSORRT_LLM_HOST_NAME=

# Hugging Face cache/auth used by engine containers.
# Set HF_HOME to an absolute path if the default ~/.cache/huggingface is not
# where your model cache lives.
# HF_HOME=/home/ubuntu/.cache/huggingface
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
