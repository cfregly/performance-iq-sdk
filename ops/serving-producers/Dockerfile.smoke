FROM python:3.12-slim

LABEL org.opencontainers.image.title="Performance IQ Serving Producer Smoke"
LABEL org.opencontainers.image.description="Runs model-aware vLLM, SGLang, and TensorRT-LLM producer smoke submissions."

ENV PYTHONUNBUFFERED=1

WORKDIR /opt/performance-iq-sdk

COPY python/pyproject.toml python/README.md ./python/
COPY python/src ./python/src

RUN python -m pip install --no-cache-dir "./python[tokenizers]"

ENTRYPOINT ["python", "-m", "performance_iq_sdk.serving_smoke"]
