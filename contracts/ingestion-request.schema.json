{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://performance-iq.dev/contracts/ingestion-request.v1",
  "title": "Performance IQ Ingestion Request v1",
  "type": "object",
  "required": ["schemaVersion", "manifest", "measurements"],
  "properties": {
    "schemaVersion": { "const": "performance-iq.ingestion-request.v1" },
    "manifest": { "$ref": "producer-run-manifest.schema.json" },
    "evaluationId": { "type": "string", "minLength": 1, "maxLength": 200 },
    "measurements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    }
  },
  "additionalProperties": false
}
