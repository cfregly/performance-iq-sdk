{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://performance-iq.dev/contracts/persistence-receipt.v1",
  "title": "Performance IQ Persistence Receipt v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "tenantId",
    "runId",
    "campaignId",
    "idempotencyKeySha256",
    "envelopeSha256",
    "bundleUri",
    "bundleSha256",
    "nessieCommitHash",
    "stagingBranch",
    "stagingCommitHash",
    "tableSnapshots",
    "persistedAtUtc"
  ],
  "properties": {
    "schemaVersion": { "const": "performance-iq.persistence-receipt.v1" },
    "tenantId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "campaignId": { "type": "string", "minLength": 1 },
    "idempotencyKeySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "envelopeSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "bundleUri": { "type": "string", "minLength": 1 },
    "bundleSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nessieCommitHash": { "type": "string", "minLength": 1 },
    "stagingBranch": { "type": "string", "minLength": 1 },
    "stagingCommitHash": { "type": ["string", "null"] },
    "tableSnapshots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["table", "rowCount"],
        "properties": {
          "table": { "type": "string", "minLength": 1 },
          "snapshotId": { "type": ["integer", "null"] },
          "rowCount": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "persistedAtUtc": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
