{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://performance-iq.example/schemas/deal-packet.v1.json",
  "title": "Performance IQ Deal Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifest", "packetScope", "campaignCensus"],
  "properties": {
    "schemaVersion": {
      "const": "performance-iq.deal-packet.v1"
    },
    "manifest": {
      "type": "object",
      "minProperties": 1
    },
    "packetScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["testedConfigurationOnly", "buyerQuestion", "workloadWindow", "notAServiceCommitment", "limitationsEcho"],
      "properties": {
        "testedConfigurationOnly": { "const": true },
        "buyerQuestion": { "type": "string", "minLength": 1 },
        "workloadWindow": { "type": "string", "minLength": 1 },
        "notAServiceCommitment": { "const": true },
        "limitationsEcho": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "campaignCensus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaignsRunForDeal", "exportedFromCampaign", "attestedBy"],
      "properties": {
        "campaignsRunForDeal": { "type": "integer", "minimum": 1 },
        "exportedFromCampaign": { "type": "string", "minLength": 1 },
        "attestedBy": { "const": "operator" }
      }
    },
    "buyerWorkloadAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["specFileName", "specSha256"],
      "properties": {
        "specFileName": { "type": "string", "minLength": 1 },
        "specSha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" }
      }
    },
    "countersignature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["keyId", "signature", "mode", "signedAtUtc"],
      "properties": {
        "keyId": { "type": "string", "minLength": 1 },
        "signature": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["vendor-ed25519", "demo-self-signed"] },
        "signedAtUtc": { "type": "string", "format": "date-time" }
      }
    },
    "transparencyLog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "prevEntryDigest", "entryDigest", "packetDigest", "digestAlgorithm", "keyId", "signedAtUtc"],
      "properties": {
        "seq": { "type": "integer", "minimum": 1 },
        "prevEntryDigest": {
          "anyOf": [
            { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
            { "type": "null" }
          ]
        },
        "entryDigest": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "packetDigest": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "digestAlgorithm": { "const": "sha256" },
        "keyId": { "type": "string", "minLength": 1 },
        "signedAtUtc": { "type": "string", "format": "date-time" },
        "tenantIdHash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "dealIdHash": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "logUrl": { "type": "string" },
        "logPath": { "type": "string" },
        "checkpoint": { "type": "string" }
      }
    }
  }
}
